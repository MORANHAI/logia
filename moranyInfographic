import React, { useState } from 'react';
import { 
  Play, 
  Pause, 
  RotateCcw, 
  XCircle, 
  Eye, 
  Zap, 
  Layers,
  Info,
  ArrowDown,
  RefreshCw,
  Terminal
} from 'lucide-react';

const App = () => {
  const [activeStep, setActiveStep] = useState(null);

  const lifecycleData = {
    onCreate: {
      title: "onCreate()",
      desc: "נקודת ההתחלה! כאן הקוד 'נולד'. המערכת יוצרת את האובייקט בזיכרון. זה המקום היחיד שבו מגדירים את העיצוב (setContentView) ומחברים את הכפתורים (findViewById).",
      status: "Created",
      color: "bg-amber-500",
      icon: <Layers className="w-6 h-6" />
    },
    onStart: {
      title: "onStart()",
      desc: "האפליקציה עולה על המסך! המשתמש כבר יכול לראות אותה, אבל היא עדיין לא מגיבה למגע. זהו שלב הכנה קצר מאוד לפני שהיא הופכת לפעילה.",
      status: "Started",
      color: "bg-orange-500",
      icon: <Eye className="w-6 h-6" />
    },
    onResume: {
      title: "onResume()",
      desc: "זהו! האפליקציה 'על הגובה'. המשתמש יכול להקליד, ללחוץ ולשחק. כאן אנחנו מפעילים מצלמה, אנימציות או חיישנים שהיו בהפסקה.",
      status: "Resumed",
      color: "bg-emerald-500",
      icon: <Play className="w-6 h-6" />
    },
    running: {
      title: "Activity is Running",
      desc: "זהו מצב הפעולה הרגיל. האפליקציה נמצאת ב-Foreground. היא מחזיקה ב'פוקוס' של המערכת וצורכת משאבים כדי לתת חווית משתמש חלקה.",
      status: "Active",
      color: "bg-gradient-to-r from-emerald-500 to-teal-600",
      icon: <Zap className="w-6 h-6" />
    },
    onPause: {
      title: "onPause()",
      desc: "רגע, משהו מפריע! מופיע חלון קטן מעל, או שהמשתמש עבר לאפליקציה אחרת. האפליקציה עדיין נראית חלקית אבל היא כבר לא 'הראשית'. זמן טוב לשמור נתונים דחופים.",
      status: "Paused",
      color: "bg-rose-500",
      icon: <Pause className="w-6 h-6" />
    },
    onStop: {
      title: "onStop()",
      desc: "המסך נעלם לגמרי. האפליקציה כבר לא נראית. היא עדיין בזיכרון, אבל היא 'ישנה'. המערכת עלולה לסגור אותה אם ייגמר הזיכרון (RAM).",
      status: "Stopped",
      color: "bg-red-600",
      icon: <RotateCcw className="w-6 h-6" />
    },
    onDestroy: {
      title: "onDestroy()",
      desc: "הסוף הגיע. ה-Activity מושמדת. הזיכרון מתנקה. זה קורה כי קראנו ל-finish() או שהמשתמש סגר את האפליקציה מהרשימה.",
      status: "Destroyed",
      color: "bg-slate-900",
      icon: <XCircle className="w-6 h-6" />
    }
  };

  const Step = ({ id, label, customColor, isRunningNode = false }) => {
    const data = lifecycleData[id];
    const isActive = activeStep === id;

    return (
      <div 
        onClick={() => setActiveStep(id)}
        className={`
          relative flex items-center p-4 my-2 rounded-2xl border-l-8 transition-all cursor-pointer shadow-md
          ${isActive ? 'scale-105 ring-4 ring-amber-300' : 'hover:translate-x-2'}
          ${customColor || 'bg-white border-amber-500'}
        `}
      >
        <div className={`p-3 rounded-xl ml-4 ${data?.color || 'bg-slate-700'} text-white shadow-inner`}>
          {data?.icon}
        </div>
        <div className="flex-grow text-left flex flex-col">
          <span className="font-mono font-bold text-lg text-slate-800" dir="ltr">{label}</span>
          <span className="text-[10px] font-bold text-slate-400 uppercase tracking-tighter" dir="rtl">מצב: {data?.status}</span>
        </div>
        <Info className={`w-5 h-5 ${isActive ? 'text-amber-600' : 'text-slate-300'}`} />
      </div>
    );
  };

  return (
    <div className="min-h-screen bg-[#1a1a1c] text-slate-100 p-6 md:p-12 font-sans" dir="rtl">
      <div className="max-w-5xl mx-auto">
        {/* Header Section */}
        <header className="flex flex-col md:flex-row items-center justify-between mb-16 bg-gradient-to-l from-amber-900/20 to-transparent p-8 rounded-3xl border border-amber-900/30">
          <div>
            <h1 className="text-5xl font-black text-amber-500 mb-4 drop-shadow-sm">Activity Lifecycle</h1>
            <p className="text-xl text-slate-300 max-w-lg leading-relaxed">
              המדריך הוויזואלי המלא למחזור החיים באנדרואיד. 
              <span className="block mt-2 text-amber-200/60 text-sm italic font-light">לחצו על השלבים כדי לחקור מה קורה 'מתחת למכסה המנוע'.</span>
            </p>
          </div>
          <div className="mt-8 md:mt-0 flex gap-4">
            <div className="bg-amber-500/10 p-6 rounded-2xl border border-amber-500/20 text-center">
              <span className="block text-3xl font-bold text-amber-500">7</span>
              <span className="text-[10px] uppercase text-amber-200">שלבים קריטיים</span>
            </div>
            <div className="bg-emerald-500/10 p-6 rounded-2xl border border-emerald-500/20 text-center">
              <span className="block text-3xl font-bold text-emerald-500">3</span>
              <span className="text-[10px] uppercase text-emerald-200">מצבי נראות</span>
            </div>
          </div>
        </header>

        <div className="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
          
          {/* Infographic Column */}
          <div className="lg:col-span-5 space-y-1">
            
            <div className="flex justify-center mb-4">
              <div className="px-4 py-1 bg-amber-500 text-slate-900 rounded-full text-xs font-black uppercase">App Launch</div>
            </div>

            <Step id="onCreate" label="onCreate()" />
            <div className="flex justify-center py-1"><ArrowDown className="text-amber-500/50 w-6 h-6" /></div>
            
            <Step id="onStart" label="onStart()" />
            <div className="flex justify-center py-1"><ArrowDown className="text-orange-500/50 w-6 h-6" /></div>
            
            <Step id="onResume" label="onResume()" />
            <div className="flex justify-center py-1"><ArrowDown className="text-emerald-500/50 w-6 h-6" /></div>

            {/* THE HUB - Running State */}
            <div 
              onClick={() => setActiveStep('running')}
              className={`
                group relative p-8 my-6 rounded-[2.5rem] border-4 border-emerald-500/30 bg-[#252528] cursor-pointer
                transition-all duration-300 hover:border-emerald-400 shadow-[0_0_30px_rgba(16,185,129,0.1)]
                ${activeStep === 'running' ? 'ring-4 ring-emerald-400 bg-emerald-950/20' : ''}
              `}
            >
              <div className="flex items-center justify-center gap-4">
                <div className="relative">
                  <div className="absolute inset-0 bg-emerald-500 blur-xl opacity-20 group-hover:opacity-40 transition-opacity animate-pulse"></div>
                  <Play className="w-12 h-12 text-emerald-500 relative fill-current" />
                </div>
                <div className="text-center">
                  <h3 className="text-2xl font-black text-emerald-400 uppercase tracking-wide">Activity Running</h3>
                  <p className="text-[10px] text-emerald-200/50 font-mono tracking-widest">USER INTERACTION ENABLED</p>
                </div>
              </div>
            </div>

            <div className="flex justify-center py-1"><ArrowDown className="text-rose-500/50 w-6 h-6" /></div>
            <Step id="onPause" label="onPause()" customColor="bg-white border-rose-500" />
            
            <div className="flex justify-center py-1"><ArrowDown className="text-red-600/50 w-6 h-6" /></div>
            <Step id="onStop" label="onStop()" customColor="bg-white border-red-600" />
            
            <div className="flex justify-center py-1"><ArrowDown className="text-slate-900/50 w-6 h-6" /></div>
            <Step id="onDestroy" label="onDestroy()" customColor="bg-white border-slate-900" />

            <div className="flex justify-center mt-6">
              <div className="px-4 py-1 bg-slate-800 text-slate-400 rounded-full text-xs font-black uppercase border border-slate-700">App Closed</div>
            </div>
          </div>

          {/* Details & Knowledge Base Column */}
          <div className="lg:col-span-7 sticky top-12">
            
            {/* The "Brain" Display */}
            <div className={`
              min-h-[400px] p-10 rounded-[3rem] transition-all duration-700 border-2
              ${activeStep ? 'bg-[#252528] border-amber-500/50 shadow-2xl' : 'bg-transparent border-dashed border-slate-800'}
            `}>
              {!activeStep ? (
                <div className="h-full flex flex-col items-center justify-center text-center opacity-40">
                  <Terminal className="w-20 h-20 mb-6 text-slate-600" />
                  <h2 className="text-2xl font-bold mb-2">ממתין לפקודה...</h2>
                  <p>לחצו על אחד השלבים בתרשים כדי לראות את הלוגיקה</p>
                </div>
              ) : (
                <div className="animate-in fade-in zoom-in-95 duration-500">
                  <div className="flex items-center gap-4 mb-8">
                    <div className={`p-4 rounded-2xl shadow-lg ${lifecycleData[activeStep].color}`}>
                      {lifecycleData[activeStep].icon}
                    </div>
                    <div>
                      <h2 className="text-4xl font-black text-white" dir="ltr">{lifecycleData[activeStep].title}</h2>
                      <div className="flex items-center gap-2 mt-1">
                        <span className="text-amber-500 font-mono text-sm tracking-wider uppercase">{lifecycleData[activeStep].status}</span>
                        <div className="h-px w-12 bg-slate-700"></div>
                      </div>
                    </div>
                  </div>

                  <div className="bg-slate-800/40 p-6 rounded-2xl border border-slate-700/50 mb-8">
                    <p className="text-2xl leading-relaxed text-slate-200">
                      {lifecycleData[activeStep].desc}
                    </p>
                  </div>

                  <div className="grid grid-cols-2 gap-4">
                    <div className="bg-amber-500/5 p-4 rounded-xl border border-amber-500/10">
                      <h4 className="text-[10px] font-bold text-amber-500/70 mb-2 uppercase tracking-widest">Pro Tip</h4>
                      <p className="text-xs text-amber-100/70 italic">תמיד זכרו לשחרר משאבים כבדים בשלב זה כדי למנוע Memory Leaks.</p>
                    </div>
                    <div className="bg-blue-500/5 p-4 rounded-xl border border-blue-500/10">
                      <h4 className="text-[10px] font-bold text-blue-500/70 mb-2 uppercase tracking-widest">Context</h4>
                      <p className="text-xs text-blue-100/70 italic">שלב זה הוא חלק ממעגל ה-{' '}{activeStep === 'onCreate' || activeStep === 'onDestroy' ? 'Full' : 'Visible'}{' '} Lifecycle.</p>
                    </div>
                  </div>
                </div>
              )}
            </div>

            {/* Quick Summary Cards */}
            <div className="mt-8 grid grid-cols-3 gap-4 text-center">
              <div className="bg-[#1f1f22] p-4 rounded-2xl border border-slate-800 hover:border-amber-500/40 transition-colors">
                <RefreshCw className="w-5 h-5 mx-auto mb-2 text-amber-500" />
                <span className="block text-[10px] font-bold text-slate-500 uppercase">Configuration Change</span>
                <p className="text-[9px] text-slate-400 mt-1">סיבוב מסך = השמדה ובנייה מחדש!</p>
              </div>
              <div className="bg-[#1f1f22] p-4 rounded-2xl border border-slate-800 hover:border-emerald-500/40 transition-colors">
                <Zap className="w-5 h-5 mx-auto mb-2 text-emerald-500" />
                <span className="block text-[10px] font-bold text-slate-500 uppercase">Energy Impact</span>
                <p className="text-[9px] text-slate-400 mt-1">מצב Resumed הוא היקר ביותר בסוללה.</p>
              </div>
              <div className="bg-[#1f1f22] p-4 rounded-2xl border border-slate-800 hover:border-rose-500/40 transition-colors">
                <Info className="w-5 h-5 mx-auto mb-2 text-rose-500" />
                <span className="block text-[10px] font-bold text-slate-500 uppercase">Back Stack</span>
                <p className="text-[9px] text-slate-400 mt-1">לחיצה על 'Back' קוראת ל-finish().</p>
              </div>
            </div>
          </div>

        </div>

        {/* Footer Legend */}
        <footer className="mt-20 pt-8 border-t border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4 text-slate-500 text-sm">
          <div className="flex gap-6">
            <div className="flex items-center gap-2">
              <div className="w-3 h-3 rounded-full bg-amber-500"></div>
              <span>יצירה</span>
            </div>
            <div className="flex items-center gap-2">
              <div className="w-3 h-3 rounded-full bg-emerald-500"></div>
              <span>פעולה</span>
            </div>
            <div className="flex items-center gap-2">
              <div className="w-3 h-3 rounded-full bg-red-600"></div>
              <span>סגירה</span>
            </div>
          </div>
          <p className="font-mono text-[10px]">Android Dev Mastery // 11th-12th Grade Edition</p>
        </footer>
      </div>
    </div>
  );
};

export default App;
